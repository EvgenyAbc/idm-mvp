# Single LDAP server for ldapsearch / ldapmodify / ldapwhoami (fixes reconcile vs ldap.conf mismatches).
# LDAP_URI=
# Optional seconds for ldap_bind / libldap network operations (PHP ldap extension).
# LDAP_NETWORK_TIMEOUT_SEC=5
# Microseconds between per-user password checks during reconcile (reduces slapd bursts). 0 = off.
# RECONCILE_PASSWORD_VERIFY_DELAY_US=3000
# Server-side default: sync LDAP userPassword from CSV during reconcile (same as dashboard checkbox).
# RECONCILE_SYNC_PASSWORDS=0

LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_PASSWORD=123
ADMIN_USERNAME=alphaadmin
RBAC_BOOTSTRAP_ADMIN=true
CSV_SOURCE_PATH=../storage/csv/source.csv
BACKEND_PORT=8080
